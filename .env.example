# ============================================================
# JyotishGPT — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# REQUIRED: Anthropic API Key for Claude LLM
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# Data directory for SQLite database (used by Docker for volume mounts)
# Leave unset for local development (defaults to current directory)
# DATA_DIR=/app/data
